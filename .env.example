# ─────────────────────────────────────────────────────────────────────────────
# NexDash — Environment Variables
# Copy this file to .env.local and fill in the values.
# .env.local is gitignored — never commit secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── API ───────────────────────────────────────────────────────────────────────

# Base URL of the backend API.
# Must be a valid URL or empty string (empty = same-origin, e.g. /api).
# Only required when NEXT_PUBLIC_USE_MOCKS=false.
# Default: "" (same-origin)
NEXT_PUBLIC_API_URL=

# If "true", all data handlers serve mock data and never call the API.
# Set to "false" to route every request through NEXT_PUBLIC_API_URL.
# Requires a dev-server restart after changing.
# Default: true
NEXT_PUBLIC_USE_MOCKS=true

# ── App ───────────────────────────────────────────────────────────────────────

# Display name of the app. Used in the page title and the sidebar logo.
# Default: NexDash
# NEXT_PUBLIC_APP_NAME=NexDash
